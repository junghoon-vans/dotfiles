// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "context_servers": {
    "mcp-server-brave-search": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "lsp": {
    "gopls": {
      "binary": {
        "path": "/bin/bash",
        "arguments": ["-lc", "PATH=\"$HOME/.local/bin:$PATH\" exec mise exec go@1.25 -- gopls"],
      },
    },
    "gnopls": {
      "binary": {
        "path": "/bin/bash",
        "arguments": ["-lc", "PATH=\"$HOME/.local/bin:$PATH\" exec mise exec go@1.25 -- gnopls -mode=stdio"],
      },
    },
  },
  "languages": {
    "Go": {
      "language_servers": ["gopls"],
    },
    "Gno": {
      "language_servers": ["gnopls"],
      "format_on_save": "on",
      "tab_size": 4,
    },
    "SQL": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false,
      },
    },
    "YAML": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false,
      },
    },
  },
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "model_parameters": [],
  },
  "disable_ai": false,
  "confirm_quit": true,
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "minimap": {
    "show": "auto",
  },
  "autosave": "on_focus_change",
  "base_keymap": "JetBrains",
  "icon_theme": "Catppuccin Macchiato",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
}
