#!/bin/bash
# Description: Install Homebrew if it is missing and initialize brew shellenv.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/common.sh"

ensure_zprofile_runtime_environment() {
    local zprofile="$HOME/.zprofile"
    local temp_file=""

    mkdir -p "$(dirname "$zprofile")"
    temp_file="$(mktemp)"

    if [ -f "$zprofile" ]; then
        awk '
            /^# >>> dotfiles runtime environment >>>$/ { skip = 1; next }
            /^# <<< dotfiles runtime environment <<<$/ { skip = 0; next }
            skip != 1 { print }
        ' "$zprofile" >"$temp_file"
    fi

    {
        printf '\n# >>> dotfiles runtime environment >>>\n'
        printf 'if command -v brew >/dev/null 2>&1; then\n'
        printf '  eval "$(brew shellenv)"\n'
        printf 'elif [ -x "/opt/homebrew/bin/brew" ]; then\n'
        printf '  eval "$(/opt/homebrew/bin/brew shellenv)"\n'
        printf 'elif [ -x "/usr/local/bin/brew" ]; then\n'
        printf '  eval "$(/usr/local/bin/brew shellenv)"\n'
        printf 'fi\n\n'
        printf 'unset GOROOT\n'
        printf 'if command -v mise >/dev/null 2>&1; then\n'
        printf '  eval "$(mise activate zsh)"\n'
        printf '  unset GOROOT\n'
        printf 'fi\n'
        printf '# <<< dotfiles runtime environment <<<\n'
    } >>"$temp_file"

    mv "$temp_file" "$zprofile"
}

print_step "Checking Homebrew..."

if ! command -v brew &> /dev/null; then
    print_info "Homebrew not found. Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    homebrew_prefix="$(detect_homebrew_prefix)"
    if [ -n "$homebrew_prefix" ] && [ -x "$homebrew_prefix/bin/brew" ]; then
        ensure_zprofile_runtime_environment
        eval "$("$homebrew_prefix/bin/brew" shellenv)"
    fi

    print_success "Homebrew installed successfully"
else
    ensure_zprofile_runtime_environment
    print_success "Homebrew already installed"
fi
