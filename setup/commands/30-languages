#!/bin/bash
# Description: Run all language commands: go, node, bun, java, rust, python, gno, and typescript.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/common.sh"

for language_name in go node bun java rust python gno typescript; do
    case "${SETUP_SKIP_COMMANDS:-}" in
        *" $language_name "*)
            print_info "Skipping language command: $language_name"
            continue
            ;;
    esac

    bash "$SETUP_DIR/languages/$language_name.sh"
done
