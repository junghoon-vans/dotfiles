#!/bin/bash
# Description: Run all language commands: go, node, bun, java, xml, rust, python, gno, and typescript.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/common.sh"

for language_name in go node bun java xml rust python gno typescript; do
    case "${SETUP_SKIP_COMMANDS:-}" in
        *" $language_name "*)
            print_info "Skipping language command: $language_name"
            continue
            ;;
    esac

    if ! confirm "Run language command '$language_name'?" "yes"; then
        print_info "Skipped language command: $language_name"
        continue
    fi

    bash "$SETUP_DIR/languages/$language_name.sh"
done
