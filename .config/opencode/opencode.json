{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "@warp-dot-dev/opencode-warp"
  ],
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp/authv2",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  },
  "lsp": {
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md"
      ]
    },
    "gnopls": {
      "command": [
        "gnopls",
        "-mode=stdio"
      ],
      "extensions": [
        ".gno"
      ]
    },
    "ruby-lsp-extensionless": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [
        ""
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    },
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  }
}
