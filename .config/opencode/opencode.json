{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "lsp": {
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md"
      ]
    },
    "gnopls": {
      "command": [
        "gnopls",
        "-mode=stdio"
      ],
      "extensions": [
        ".gno"
      ]
    },
    "ruby-lsp-extensionless": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [
        ""
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    }
  }
}
