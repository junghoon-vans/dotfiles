// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "lsp": {
    "gopls": {
      "binary": {
        "path": "~/go/bin/gopls"
      }
    },
    "gnopls": {
      "binary": {
        "path": "~/go/bin/gnopls",
        "arguments": [
          "-mode=stdio"
        ]
      }
    }
  },
  "languages": {
    "Go": {
      "language_servers": [
        "gopls"
      ]
    },
    "C++": {
      "language_servers": [
        "gnopls"
      ],
      "format_on_save": "on",
      "tab_size": 4
    },
    "SQL": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false
      }
    },
    "YAML": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false
      }
    }
  },
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "model_parameters": []
  },
  "features": {
    "edit_prediction_provider": "copilot"
  },
  "disable_ai": false,
  "confirm_quit": true,
  "agent_servers": {
    "codex": {
      "favorite_config_option_values": {
        "model": [
          "gpt-5.4"
        ]
      }
    }
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true
  },
  "minimap": {
    "show": "auto"
  },
  "autosave": "on_focus_change",
  "file_types": {
    "C++": [
      "gno"
    ]
  },
  "base_keymap": "JetBrains",
  "icon_theme": "Catppuccin Macchiato",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato"
  }
}